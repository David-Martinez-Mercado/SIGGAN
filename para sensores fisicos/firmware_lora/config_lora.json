{
  "lora": {
    "frecuencia_mhz": 915.0,
    "spreading_factor": 12,
    "bandwidth_khz": 125,
    "coding_rate": "4/5",
    "tx_power_dbm": 20,
    "sync_word": "0x12",
    "preamble_length": 8,
    "crc_enabled": true,
    "region": "AU915"
  },
  "encriptacion": {
    "algoritmo": "AES-128-CBC",
    "clave_base64": "U0lHR0FOX0xPUkFfS0VZXzIwMjY=",
    "iv_base64": "AAAAAAAAAAAAAAAAAAAAAA==",
    "hmac_algoritmo": "SHA256",
    "hmac_clave_base64": "U0lHR0FOX0hNQUNfU0VDUkVUXzIwMjY="
  },
  "payload": {
    "version": 1,
    "tamano_bytes": 40,
    "campos": {
      "version":        { "offset": 0, "bytes": 1,  "tipo": "uint8"  },
      "device_id":      { "offset": 1, "bytes": 4,  "tipo": "uint32" },
      "timestamp":      { "offset": 5, "bytes": 4,  "tipo": "uint32" },
      "latitud":        { "offset": 9, "bytes": 4,  "tipo": "int32", "factor": 1e6 },
      "longitud":       { "offset": 13, "bytes": 4, "tipo": "int32", "factor": 1e6 },
      "temperatura":    { "offset": 17, "bytes": 2, "tipo": "uint16", "factor": 10  },
      "ritmo_cardiaco": { "offset": 19, "bytes": 2, "tipo": "uint16"  },
      "saturacion_o2":  { "offset": 21, "bytes": 1, "tipo": "uint8"   },
      "estres":         { "offset": 22, "bytes": 1, "tipo": "uint8"   },
      "actividad":      { "offset": 23, "bytes": 1, "tipo": "uint8", "enum": { "0": "reposo", "1": "caminando", "2": "comiendo", "3": "corriendo" } },
      "rssi":           { "offset": 24, "bytes": 1, "tipo": "int8"    },
      "bateria":        { "offset": 25, "bytes": 1, "tipo": "uint8"   },
      "rfid_tag":       { "offset": 26, "bytes": 8, "tipo": "bytes"   },
      "crc16":          { "offset": 34, "bytes": 2, "tipo": "uint16"  },
      "hmac_4bytes":    { "offset": 36, "bytes": 4, "tipo": "bytes"   }
    }
  },
  "gpio_esp32": {
    "max30102": { "sda": 21, "scl": 22 },
    "dht22":    { "data": 4 },
    "mpu6050":  { "sda": 21, "scl": 22 },
    "rfid_rc522": { "ss": 5, "rst": 27, "mosi": 23, "miso": 19, "sck": 18 },
    "lora_sx1276": {
      "nss": 18, "reset": 14, "dio0": 26,
      "mosi": 23, "miso": 19, "sck": 5
    },
    "led_status": 2,
    "boton_config": 0
  },
  "gateway_raspberry": {
    "puerto_serial": "/dev/ttyS0",
    "baud_rate": 9600,
    "backup_sd_path": "/mnt/sd/lecturas",
    "api_url": "http://localhost:3001",
    "api_timeout_ms": 3000,
    "reintentos": 3,
    "backoff_base_ms": 500
  },
  "ciclos": {
    "lectura_sensores_ms": 300000,
    "sleep_profundo_ms": 295000,
    "estadisticas_gateway_ms": 60000,
    "ntp_sync_intervalo_ms": 3600000
  }
}
