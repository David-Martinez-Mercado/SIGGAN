generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUARIOS ====================
model Usuario {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  nombre        String
  apellidos     String
  rol           Rol           @default(PRODUCTOR)
  telefono      String?
  estatus       EstatusUsuario @default(PENDIENTE)
  activo        Boolean       @default(true)

  // Campos comunes
  rfc           String?
  curp          String?
  direccion     String?
  municipio     String?
  estado        String?       @default("Durango")

  // Campos de Agricultor/Propietario
  // (documentos se guardan como rutas de archivo en DocumentoUsuario)

  // Campos de MVZ
  cedulaProfesional   String?
  credencialSenasica  String?
  vigenciaCredencial  DateTime?
  ddr                 String?   // Distrito de Desarrollo Rural

  // Admin
  creadoPorId   String?       // Quién lo creó (para Super Admin → Admin)
  creadoPor     Usuario?      @relation("CreadorAdmin", fields: [creadoPorId], references: [id])
  adminsCreados Usuario[]     @relation("CreadorAdmin")
  esSuperAdmin  Boolean       @default(false)
  esPrimario    Boolean       @default(false)  // Solo 1: el Super Admin original

  // Suspensión
  motivoSuspension  String?
  tipoSuspension    TipoSuspension?
  suspendidoAt      DateTime?
  suspendidoPorId   String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  propiedades   Propietario[]
  formularios   Formulario[]
  documentos    DocumentoUsuario[]

  @@map("usuarios")
}

enum Rol {
  SUPER_ADMIN
  ADMIN
  PRODUCTOR
  MVZ
}

enum EstatusUsuario {
  PENDIENTE
  ACTIVO
  SUSPENDIDO_TEMPORAL
  SUSPENDIDO_DEFINITIVO
}

enum TipoSuspension {
  TEMPORAL
  DEFINITIVO
}

// ==================== DOCUMENTOS DE USUARIO ====================
model DocumentoUsuario {
  id            String   @id @default(uuid())
  tipo          TipoDocumento
  nombreArchivo String
  rutaArchivo   String
  mimeType      String?
  size          Int?
  createdAt     DateTime @default(now())

  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("documentos_usuario")
}

enum TipoDocumento {
  INE
  EFIRMA_CER
  EFIRMA_KEY
  REGISTRO_SAT
  DOCUMENTO_PROPIEDAD
  RECIBO_COMPROBANTE
  CREDENCIAL_SENASICA
  CEDULA_PROFESIONAL
}

// ==================== PROPIETARIOS ====================
model Propietario {
  id            String   @id @default(uuid())
  nombre        String
  apellidos     String
  email         String?
  curp          String?  @unique
  rfc           String?
  telefono      String?
  direccion     String?
  municipio     String
  estado        String   @default("Durango")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuarioId     String?
  usuario       Usuario?  @relation(fields: [usuarioId], references: [id])
  upps          UPP[]
  animales      Animal[]
  ventasComoVendedor    OfertaMarketplace[] @relation("Vendedor")
  ventasComoComprador   OfertaMarketplace[] @relation("Comprador")

  @@map("propietarios")
}

// ==================== UPP ====================
model UPP {
  id              String   @id @default(uuid())
  claveUPP        String   @unique
  nombre          String
  direccion       String?
  municipio       String
  estado          String   @default("Durango")
  telefono        String?
  email           String?
  latitud         Float?
  longitud        Float?
  tipoExplotacion String?
  estatusSanitario String  @default("EN_PROCESO")
  superficieHa    Float?
  capacidadAnimales Int?
  activa          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  propietarioId   String
  propietario     Propietario @relation(fields: [propietarioId], references: [id])
  animales        Animal[]

  @@map("upps")
}

// ==================== ANIMALES ====================
model Animal {
  id              String   @id @default(uuid())
  areteNacional   String   @unique
  areteExportacion String? @unique
  rfidTag         String?  @unique
  nombre          String?
  raza            String
  sexo            Sexo
  fechaNacimiento DateTime
  color           String?
  peso            Float?
  pesoNacimiento  Float?
  horaNacimiento  String?
  condicionCorporal Float?
  areteNacionalPadre String?
  razaPadre       String?
  tipoParto       String?
  esGemelar       Boolean? @default(false)
  numCriaCamada   Int?
  estatusSanitario String  @default("SANO")
  proposito       String?
  activo          Boolean  @default(true)
  irisHash        String?
  blockchainTokenId String?
  blockchainTxHash  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  propietarioId   String
  propietario     Propietario @relation(fields: [propietarioId], references: [id])
  uppId           String
  upp             UPP      @relation(fields: [uppId], references: [id])
  eventos         EventoSanitario[]
  aretes          HistorialArete[]
  lecturas        LecturaIoT[]
  publicaciones   OfertaMarketplace[]

  madreId         String?
  madre           Animal?  @relation("Genealogia", fields: [madreId], references: [id])
  crias           Animal[] @relation("Genealogia")

  @@map("animales")
}

enum Sexo {
  MACHO
  HEMBRA
}

// ==================== EVENTOS SANITARIOS ====================
model EventoSanitario {
  id              String   @id @default(uuid())
  tipo            TipoEvento
  descripcion     String?
  fecha           DateTime
  resultado       String?
  mvzResponsable  String?
  cedulaMvz       String?
  rnmvz           String?
  vigenciaMvz     String?
  observaciones   String?
  lote            String?
  proximaFecha    DateTime?
  createdAt       DateTime @default(now())

  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id])

  @@map("eventos_sanitarios")
}

enum TipoEvento {
  VACUNACION
  PRUEBA_TB
  PRUEBA_BR
  DESPARASITACION
  TRATAMIENTO
  PESAJE
  INSPECCION
  OTRO
}

// ==================== HISTORIAL DE ARETES ====================
model HistorialArete {
  id              String   @id @default(uuid())
  tipoArete       String
  numeroArete     String
  accion          String
  motivo          String?
  fecha           DateTime @default(now())

  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id])

  @@map("historial_aretes")
}

// ==================== FORMULARIOS SENASICA ====================
model Formulario {
  id              String   @id @default(uuid())
  tipo            TipoFormulario
  folio           String   @unique
  datos           Json
  estatus         String   @default("BORRADOR")
  pdfUrl          String?
  qrCode          String?
  hashBlockchain  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuarioId       String
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("formularios")
}

enum TipoFormulario {
  SOLICITUD_TB_BR
  PROGRAMACION_CAMPO
  SOLICITUD_ARETES_EXPORTACION
  GUIA_REEMO
  CERTIFICADO_ZOOSANITARIO
  ACTA_NACIMIENTO
  CONTRATO_COMPRAVENTA
}

// ==================== POOL DE ARETES ====================
model AreteDisponible {
  id        String    @id @default(uuid())
  numero    String    @unique
  tipo      String    // 'NACIONAL' | 'EXPORTACION'
  asignado  Boolean   @default(false)
  animalId  String?
  createdAt DateTime  @default(now())

  @@map("aretes_disponibles")
}

// ==================== LECTURAS IoT ====================
model LecturaIoT {
  id              String   @id @default(uuid())
  nodoId          String
  latitud         Float
  longitud        Float
  temperatura     Float?
  rssi            Int?
  bateria         Float?
  ritmoCardiaco   Int?
  estres          Int?
  saturacionO2    Float?
  actividad       String?
  timestamp       DateTime @default(now())

  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id])

  @@map("lecturas_iot")
}

// ==================== ALERTAS IoT ====================
model AlertaIoT {
  id              String   @id @default(uuid())
  tipo            String
  mensaje         String
  severidad       String   @default("MEDIA")
  leida           Boolean  @default(false)
  animalId        String?
  nodoId          String?
  valor           Float?
  umbral          Float?
  timestamp       DateTime @default(now())

  @@map("alertas_iot")
}

// ==================== NODOS IoT ====================
model NodoIoT {
  id              String   @id @default(uuid())
  nodoId          String?  @unique
  nombre          String
  tipo            String   @default("ESP32_LORA")
  ubicacion       String?
  latitud         Float?
  longitud        Float?
  bateria         Float?   @default(100)
  activo          Boolean  @default(true)
  ultimaConexion  DateTime?
  createdAt       DateTime @default(now())

  @@map("nodos_iot")
}

// ==================== MARKETPLACE ====================
model OfertaMarketplace {
  id              String   @id @default(uuid())
  precioSolicitado Float
  precioOfertado  Float?
  estatus         EstatusOferta @default(PUBLICADO)
  descripcion     String?
  motivoVenta     String?
  fechaPublicacion DateTime @default(now())
  fechaCierre     DateTime?

  animalId        String
  animal          Animal      @relation(fields: [animalId], references: [id])
  vendedorId      String
  vendedor        Propietario @relation("Vendedor", fields: [vendedorId], references: [id])
  compradorId     String?
  comprador       Propietario? @relation("Comprador", fields: [compradorId], references: [id])

  @@map("ofertas_marketplace")
}

enum EstatusOferta {
  PUBLICADO
  CON_OFERTA
  ACEPTADA
  EN_VERIFICACION
  TRANSFERIDA
  RECHAZADA
  CANCELADA
}

// ==================== BLOCKCHAIN SIMULADA ====================
model BlockchainSimulada {
  id           String   @id @default(uuid())
  hashActual   String   @unique
  hashAnterior String
  tipoRegistro String   // animal | evento | certificado | venta | usuario | propietario | upp | formulario | historial_arete | documento
  referenciaId String
  hashDatos    String   // SHA256 del dato serializado
  funcionMatem String   // F(data) resultado matemático
  hashFinal    String   // FINAL_HASH del dato (lo que se verifica)
  timestamp    DateTime @default(now())

  @@index([tipoRegistro, referenciaId])
  @@map("blockchain_simulada")
}

// ==================== LOGS DE INTEGRIDAD ====================
model LogIntegridad {
  id           String   @id @default(uuid())
  tipoAlerta   String   // VERIFICADO | MANIPULACION | FRAUDE | CADENA_INVALIDA
  tipoRegistro String
  referenciaId String
  detalles     String?
  timestamp    DateTime @default(now())

  @@map("logs_integridad")
}
